        "Content": {
          "assumeRole": "arn:{{ global:AWS_PARTITION }}:iam::{{ global:ACCOUNT_ID }}:role/CostOpt-Automation-{{ global:REGION }}",
          "description": "Remediation document to convert EBS gp2 volumes to gp3",
          "mainSteps": [
            {
              "action": "aws:executeAwsApi",
              "description": "Modifies the EBS volume type from gp2 to gp3",
              "inputs": {
                "Api": "ModifyVolume",
                "Service": "ec2",
                "VolumeId": "{{ volumeid }}",
                "VolumeType": "gp3",
              },
              "name": "ModifyVolume",
              "outputs": [
                {
                  "Name": "Output",
                  "Selector": "$",
                  "Type": "StringMap",
                },
              ],
            },
          ],
          "outputs": [
            "ModifyVolume.Output",
          ],
          "parameters": {
            "volumeid": {
              "description": "ID of the EBS volume to convert from gp2 to gp3",
              "type": "String",
            },
          },
          "schemaVersion": "0.3",
        },
        "DocumentFormat": "YAML",
        "DocumentType": "Automation",
        "Name": {
          "Fn::Join": [
            "",
            [
              {
                "Ref": "AWS::StackName",
              },
              "-EbsGp3Remediation",
