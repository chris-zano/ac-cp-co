# AWS CDK Environment Configuration
# Copy this file to .env and fill in your values
# Note: .env is gitignored and should not be committed

# AWS Account ID where the main stack will be deployed (delegated admin account)
CDK_DEPLOY_ACCOUNT=123456789012

# AWS Region for deployment
CDK_DEPLOY_REGION=eu-west-1

# AWS Profile to use for deployment (optional, uses default if not set)
# This should be your delegated admin account profile
AWS_PROFILE=audit

# Alternatively, you can set these via AWS CLI configuration:
# aws configure --profile audit
# Then run: AWS_PROFILE=audit cdk deploy
